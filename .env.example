# Copy to .env before running docker compose:
#   Linux/macOS:  cp .env.example .env
#   Windows CMD:  copy .env.example .env
#   PowerShell:   Copy-Item .env.example .env
#
# Used by the FastAPI service (docker-compose env_file: .env)

# OpenAI API key for LLM explanation and recommendations.
# Leave empty or omit to use rule-based fallback (llmStatus: fallback).
OPENAI_API_KEY=

# OpenAI client timeout in seconds (default: 30)
LLM_TIMEOUT_SECONDS=30

# Set to true, 1, or yes to force rule-based fallback without calling OpenAI
LLM_FORCE_FALLBACK=

# Note: docker-compose also sets AI_SERVICE_URL=http://fastapi:8000 on the
# Spring Boot service. The decision engine currently uses a hardcoded FastAPI
# URL internally; this variable is reserved for future wiring.
